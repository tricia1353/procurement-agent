# 环境变量配置

# 百度 AI Studio
LLM_ACCESS_TOKEN=your_baidu_aistudio_token_here
LLM_API_URL=https://aistudio.baidu.com

# DigiKey API（价格追踪核心）
# 获取方式: https://developer.digikey.com/
DIGIKEY_CLIENT_ID=your_digikey_client_id_here
DIGIKEY_CLIENT_SECRET=your_digikey_client_secret_here

# 天眼查 API（可选）
TIANYANCHA_API_KEY=your_tianyancha_key_here
TIANYANCHA_API_URL=https://open.api.tianyancha.com

# 电商 API（可选）
LCSC_API_KEY=

# 服务器配置
HOST=0.0.0.0
PORT=8000
